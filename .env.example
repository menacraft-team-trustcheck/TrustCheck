# ══════════════════════════════════════════════════════════════
# MENACRAFT TRUSTCHECK — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.

# Groq — Fast text inference (primary)
GROQ_API_KEY=

# DeepSeek — Deep reasoning (fallback / reasoning-first)
DEEPSEEK_API_KEY=

# OpenRouter — Free vision models (llama-3.2-11b-vision, qwen2.5-vl-7b)
OPENROUTER_API_KEY=

# HuggingFace — AI image detection inference
HF_API_KEY=

# Google — Fact Check Tools API (optional, works without key at lower rate limits)
GOOGLE_API_KEY=

# Supabase — Database & Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
